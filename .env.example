# ── Application ──
APP_NAME=webbot
DEBUG=true

# ── Database ──
# SQLite (dev)
# Relative path works on both Linux/macOS and Windows.
# On Windows you may also use an absolute path:
#   DATABASE_URL=sqlite+aiosqlite:///C:/path/to/webbot.db
DATABASE_URL=sqlite+aiosqlite:///./data/webbot.db

# PostgreSQL (prod)
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/webbot

# ── Redis ──
# Windows: install Redis via Docker, or use WSL
REDIS_URL=redis://localhost:6379/0

# ── Security ──
SECRET_KEY=change-me-in-production
API_KEY=

# ── Playwright ──
HEADLESS=true
