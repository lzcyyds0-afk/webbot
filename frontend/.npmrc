# Use a flat (npm-style) node_modules layout instead of pnpm's symlinked store.
# TypeScript (tsc) does not follow pnpm's symlinks to the .pnpm store when
# resolving a package's transitive type deps (e.g. react-router via
# react-router-dom, @socket.io/component-emitter via socket.io-client,
# rc-field-form via antd), which breaks `tsc -b` / the build. A hoisted layout
# puts those packages at the top level where tsc can find them.
node-linker=hoisted
