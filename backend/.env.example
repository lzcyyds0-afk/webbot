# Copy to .env and fill in. NEVER commit the real .env — it is gitignored and
# excluded from Docker images via .dockerignore. Provide these at runtime
# (compose env_file, container env, or your secrets manager).

# ── Security (required in production) ──
# In production (DEBUG=false) the app refuses to start without SECRET_KEY.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Optional: explicit Fernet key for encrypting stored LLM API keys.
# If empty, it is derived from SECRET_KEY.
FERNET_KEY=

# ── Runtime ──
DEBUG=false
DATABASE_URL=sqlite+aiosqlite:///./data/webbot.db
REDIS_URL=redis://localhost:6379/0

# Comma-separated allowed frontend origins (CORS). Use real origins in prod.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Engine ──
HEADLESS=true
SELF_HEAL_ENABLED=true
RUN_TIMEOUT_SECONDS=300

# ── Optional VLM fallback (app/engine/vlm.py) ──
# Only needed if you use the env-based visual path instead of a configured LLM.
VLM_ENDPOINT=https://api.openai.com/v1/chat/completions
VLM_API_KEY=
VLM_MODEL=gpt-4o
